# Copy this file to `.env` and fill in real values.
# Never commit `.env`.

# App
ENVIRONMENT=development
PORT=8080

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ebs_lite?sslmode=disable

# Auth / JWT (set a strong value in production)
JWT_SECRET=change_me_in_production
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=168h

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1h
RATE_LIMIT_KEY_BY=ip
RATE_LIMIT_KEY_PREFIX=rate_limit
RATE_LIMIT_FAIL_OPEN=true

# Redis (optional if enabled by build/config)
REDIS_URL=redis://localhost:6379

# Session activity throttling
SESSION_LAST_SEEN_THROTTLE=60s
SESSION_LAST_SEEN_USE_REDIS=true

# Uploads
MAX_UPLOAD_SIZE=10MB
UPLOAD_PATH=./uploads

# Migrations
RUN_MIGRATIONS=true
MIGRATIONS_DIR=migrations

# Password reset / deep links (used when generating reset URLs)
FRONTEND_BASE_URL=http://localhost:3000

# MQTT (optional)
MQTT_BROKER=tcp://localhost:1883
MQTT_CLIENT_ID=erp-backend
MQTT_USERNAME=
MQTT_PASSWORD=

# SMTP (optional; required for sending reset emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_user
SMTP_PASSWORD=your_password
FROM_EMAIL=no-reply@example.com

# Printing (optional)
DEFAULT_PRINTER=default
TEMPLATE_PATH=./templates
